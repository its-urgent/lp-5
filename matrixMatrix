#include <stdio.h>
#include <cuda_runtime.h>

#define N 4

__global__ void matrixMul(int A[N][N], int B[N][N], int C[N][N])
{
    int row = threadIdx.y;
    int col = threadIdx.x;

    int sum = 0;

    for (int k = 0; k < N; k++)
    {
        sum += A[row][k] * B[k][col];
    }

    C[row][col] = sum;
}

int main()
{
    int A[N][N], B[N][N], C[N][N];

    // Initialize matrices
    for (int i = 0; i < N; i++)
    {
        for (int j = 0; j < N; j++)
        {
            A[i][j] = i + j;
            B[i][j] = i * j;
        }
    }

    int (*d_A)[N], (*d_B)[N], (*d_C)[N];

    // Allocate memory on GPU
    cudaMalloc((void**)&d_A, sizeof(int) * N * N);
    cudaMalloc((void**)&d_B, sizeof(int) * N * N);
    cudaMalloc((void**)&d_C, sizeof(int) * N * N);

    // Copy matrices from CPU to GPU
    cudaMemcpy(d_A, A, sizeof(int) * N * N, cudaMemcpyHostToDevice);
    cudaMemcpy(d_B, B, sizeof(int) * N * N, cudaMemcpyHostToDevice);

    // Define thread block
    dim3 threadsPerBlock(N, N);

    // Launch kernel
    matrixMul<<<1, threadsPerBlock>>>(d_A, d_B, d_C);

    // Wait for GPU execution
    cudaDeviceSynchronize();

    // Copy result back to CPU
    cudaMemcpy(C, d_C, sizeof(int) * N * N, cudaMemcpyDeviceToHost);

    // Print result matrix
    printf("Result Matrix:\n");

    for (int i = 0; i < N; i++)
    {
        for (int j = 0; j < N; j++)
        {
            printf("%d ", C[i][j]);
        }

        printf("\n");
    }

    // Free GPU memory
    cudaFree(d_A);
    cudaFree(d_B);
    cudaFree(d_C);

    return 0;
}
